{
  "manifest_version": 3,
  "name": "DevTab",
  "version": "1.0",
  "description": "A developer new tab with HTTP codes, code snippets, trivia, and quizzes.",
  "permissions": ["search", "storage"],
  "chrome_url_overrides": {
    "newtab": "devtab.html"
  },
  "icons": {
    "16": "icons/128.png",
    "48": "icons/128.png",
    "128": "icons/128.png"
  }
}
